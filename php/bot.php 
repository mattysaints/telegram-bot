/**
 * Accredita la commissione referral (5%) al referrer quando un utente acquista.
 * La commissione viene data SOLO se l'invitato ha almeno 1 acquisto precedente (referral attivo).
 * @param int $buyerID - ID dell'utente che acquista
 * @param int $purchaseAmount - Costo dell'acquisto in crediti
 * @param string $purchaseType - Tipo di acquisto (per il log)
 */
function referral_commission($buyerID, $purchaseAmount, $purchaseType = 'acquisto') {
    global $database, $table, $api;

    // Controlla se l'utente ha un referrer
    $result = $database->query("SELECT referred_by FROM $table WHERE userID = $buyerID AND referred_by IS NOT NULL");
    if (!$result || $result->num_rows == 0) return;
    $row = $result->fetch_array(MYSQLI_ASSOC);
    $referrerID = intval($row['referred_by']);
    if ($referrerID <= 0) return;

    // Controlla che l'invitato abbia almeno 1 acquisto precedente (referral ATTIVO)
    // Cerchiamo record con crediti negativi (= acquisti) escludendo 'ruota' e 'referral_*'
    $resultAcquisti = $database->query("SELECT COUNT(*) as cnt FROM ".$table."_credits WHERE userID = $buyerID AND credits < 0 AND type NOT LIKE 'ruota' AND type NOT LIKE 'referral_%'");
    $rowAcq = $resultAcquisti->fetch_array(MYSQLI_ASSOC);
    // Il primo acquisto attiva il referral, quindi dalla seconda volta in poi (cnt >= 1 prima dell'INSERT)
    // In realtà l'INSERT dell'acquisto corrente  già avvenuto, quindi cnt >= 1 significa che questo è almeno il primo
    // Per attivare dal primo acquisto, basta cnt >= 1
    if (intval($rowAcq['cnt']) < 1) return;

    // Calcola commissione 5%
    $commission = intval(floor($purchaseAmount * 0.05));
    if ($commission < 1) return;

    // Accredita la commissione al referrer
    $database->query("INSERT INTO ".$table."_credits (userID, credits, type) VALUES ($referrerID, $commission, 'referral_commissione')");

    // Recupera username dell'acquirente per il messaggio
    $resultBuyer = $database->query("SELECT username FROM $table WHERE userID = $buyerID");
    $buyerUsername = '';
    if ($resultBuyer && $resultBuyer->num_rows > 0) {
        $rowBuyer = $resultBuyer->fetch_array(MYSQLI_ASSOC);
        $buyerUsername = $rowBuyer['username'];
    }

    // Notifica il referrer
    sm($referrerID, " <b>Commissione Referral!</b>\n\n👤 Un utente che hai invitato" . ($buyerUsername ? " (@$buyerUsername)" : "") . " ha effettuato un acquisto.\n\n💰 Hai guadagnato <b>+$commission crediti</b> (5% di $purchaseAmount).\n\n💡 <i>Continua ad invitare amici per guadagnare di più!</i>");
}

/**
 * Salva il risultato di uno spin della ruota nel file spin_log.json
 */
function logSpinResult($userID, $username, $name, $puntata, $vincita, $win) {
    $logFile = __DIR__ . '/spin_log.json';
    $logs = [];
    if (file_exists($logFile)) {
        $content = file_get_contents($logFile);
        $logs = json_decode($content, true);
        if (!$logs) $logs = [];
    }

    $logs[] = [
        'date'     => date('Y-m-d'),
        'time'     => date('H:i:s'),
        'userID'   => $userID,
        'username' => $username,
        'name'     => $name,
        'puntata'  => $puntata,
        'vincita'  => $vincita,
        'win'      => $win
    ];

    // Mantieni solo gli ultimi 90 giorni per non far crescere il file all'infinito
    $cutoffDate = date('Y-m-d', strtotime('-90 days'));
    $logs = array_values(array_filter($logs, function($entry) use ($cutoffDate) {
        return isset($entry['date']) && $entry['date'] >= $cutoffDate;
    }));

    file_put_contents($logFile, json_encode($logs, JSON_PRETTY_PRINT));
}

/**
 * Applica lo sconto VIP al costo se l'utente è VIP e lo sconto  attivo.
 * @param int $cost - Costo originale
 * @param int $userplus - 1 se VIP, 0 altrimenti
 * @return int - Costo scontato (arrotondato per difetto)
 */
function applyVipDiscount($cost, $userplus) {
    if ($userplus != 1) return $cost;
    $discountFile = __DIR__ . '/vip_discount.txt';
    if (!file_exists($discountFile)) {
        file_put_contents($discountFile, '0');
        return $cost;
    }
    $discount = intval(file_get_contents($discountFile));
    if ($discount <= 0) return $cost;
    return intval(floor($cost * (100 - $discount) / 100));
}

/**
 * Applica il cashback VIP: se l'utente è VIP e il cashback è attivo,
 * accredita una percentuale del costo speso.
 */
function applyVipCashback($userID, $userplus, $amountSpent, $table, $database) {
    if ($userplus != 1 || $amountSpent <= 0) return;
    $cashbackFile = __DIR__ . '/vip_cashback.txt';
    $percent = file_exists($cashbackFile) ? intval(file_get_contents($cashbackFile)) : 0;
    if ($percent <= 0) return;
    $cashback = max(1, intval(round($amountSpent * $percent / 100)));
    $database->query("INSERT INTO " . $table . "_credits (userID, credits, type) VALUES ($userID, $cashback, 'cashback_vip')");
    sm($userID, " <b>Cashback VIP!</b>\n\nHai ricevuto un rimborso del {$percent}% sul tuo acquisto.\n\n💰 <b>+{$cashback} crediti</b> accreditati sul tuo account.");
}

